+const sanitizePythonCode = (code: string) => {
+    if (!code) return ''
+    let cleaned = code.trim()
+    // Remove markdown code fences if present
+    cleaned = cleaned.replace(/^```(?:python|py)?\s*/i, '')
+    cleaned = cleaned.replace(/```$/i, '')
+    return cleaned.trim()
+}
+
+const generateCompletionFromMessages = async (
+    client: OpenAI,
+    model: string,
+    messages: Array<{ role: 'system' | 'user' | 'assistant'; content: string }>,
+    phase: string,
+    onLog?: (log: LangGraphLogEvent) => void,
+    onToken?: (phase: string, token: string) => void
+) => {
+    onLog?.({
+        phase,
+        type: 'request',
+        payload: {
+            model,
+            temperature: 0.2,
+            messages
+        }
+    })
+
+    const completion = await client.chat.completions.create({
+        model,
+        temperature: 0.2,
+        messages,
+        stream: true
+    })
+    let content = ''
+    for await (const chunk of completion) {
+        const token = chunk.choices?.[0]?.delta?.content || ''
+        if (!token) continue
+        content += token
+        onToken?.(phase, token)
+    }
+    onLog?.({
+        phase,
+        type: 'response',
+        payload: {
+            content
+        }
+    })
+
+    return sanitizePythonCode(content)
+}
