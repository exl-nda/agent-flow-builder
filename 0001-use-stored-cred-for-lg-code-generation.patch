     const issues: string[] = []
@@ -380,18 +436,22 @@ const generateLangGraphCodeStream = async (
     instruction?: string,
     onLog?: (log: LangGraphLogEvent) => void,
     onToken?: (phase: string, token: string) => void,
-    modelOverride?: string
